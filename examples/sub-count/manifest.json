{
  "$schema": "https://ekg.gg/schemas/manifest.json",
  "name": "Subscriber Count",
  "description": "A simple subscriber count text display",
  "version": "0.0.1",
  "js": "script.ts",
  "css": "styles.css",
  "template": "template.hbs",
  "settings": {
    "prefix": {
      "type": "string",
      "name": "Prefix",
      "default": ""
    },
    "suffix": {
      "type": "string",
      "name": "Suffix",
      "default": ""
    },
    "fontFamily": {
      "type": "font",
      "name": "Font Family",
      "default": "Inter"
    },
    "fontSize": {
      "type": "integer",
      "name": "Font Size (px)",
      "default": 24,
      "min": 12,
      "max": 72
    },
    "fontWeight": {
      "type": "integer",
      "name": "Font Weight",
      "default": 400,
      "choices": {
        "100": "100: Thin",
        "200": "200: Extra Light",
        "300": "300: Light",
        "400": "400: Normal",
        "500": "500: Medium",
        "600": "600: Semi Bold",
        "700": "700: Bold",
        "800": "800: Extra Bold",
        "900": "900: Black"
      }
    },
    "fontColor": {
      "type": "color",
      "name": "Font Color",
      "default": "#ffffff"
    },
    "outlineColor": {
      "type": "color",
      "name": "Outline Color",
      "default": "#000000"
    },
    "outlineWidth": {
      "type": "decimal",
      "name": "Outline Width",
      "default": 2.0
    }
  }
}
